{
  "name": "frontend-learning",
  "version": "1.0.0",
  "description": "Monorepo containing Vue 3 and UniApp learning projects",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:vue": "npm run dev --workspace=packages/vue-learning",
    "build:vue": "npm run build --workspace=packages/vue-learning",
    "dev:uniapp": "npm run dev:h5 --workspace=packages/uniapp-learning",
    "build:uniapp": "npm run build:h5 --workspace=packages/uniapp-learning"
  }
}